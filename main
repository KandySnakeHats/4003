            numbers.append(int(num))
    print(numbers)
    print(f'Largest: {largest(numbers)}, Smallest: {smallest(numbers)}, mode: {mode(numbers)}, median: {median(numbers)}, IQR1: {IQR1(numbers)}, IQR3: {IQR3(numbers)}')

def palindrome_substrings_counter():
    def palindrone_count(string):
        number = len(string)
        result = 0
        for left in range(number):
            for right in range((left + 1), number):
                if find_palindome(string, left, right):
                    result = result + 1
        return result
    
    def find_palindome(string, left, right):
        while left < right:
            if string[left] != string[right]:
                return False
            left = left + 1
            right = right - 1
        return True
    
    string = input(f'String: ')
    print(string)
    print(f'Number of palindrones is: {palindrone_count(string)}')


search()

