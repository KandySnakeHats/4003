#largest, smallest, mode, median, 1st IQF & 3rd IQF of an array.
def search():
    def largest(numbers):
        numb = -9999999999999999999999999
        for i in range(0,len(numbers)):
            if numbers[i] > numb:
                numb = numbers[i]
        return numb
    
    def smallest(numbers):
        numb = 9999999999999999999999999999
        for i in range(0,len(numbers)):
            if numbers[i] < numb:
                numb = numbers[i]
        return numb
    
    def mode(numbers):
        numb = 0
        mode_numb = 0
        for i in range(0,len(numbers)):
            number = 0
            for j in range(0,len(numbers)):
                if numbers[i] == numbers[j]:
                    number = number + 1
            if number > numb:
                numb = number
                mode_numb = numbers[i]
        return mode_numb
                
    def median(numbers):
        numbers.sort()
        total = len(numbers)
        if total % 2 == 0:
            med = (numbers[total//2 - 1] + numbers[total//2]) / 2
        else:
            med = numbers[total//2]
        return med

